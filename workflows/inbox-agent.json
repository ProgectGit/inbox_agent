        "mode": "retrieve-as-tool",
        "toolName": "knowledge_base",
        "toolDescription": "Search the persistent knowledge base and long-term RAG memory for information relevant to the user's request.",
        "qdrantCollection": {
          "__rl": true,
          "value": "inbox_memory",
          "mode": "list",
          "cachedResultName": "inbox_memory"
        },
        "topK": 4,
        "options": {}
